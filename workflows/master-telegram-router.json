      "id": "3289484c-dcb6-4bbc-8635-d48d5e99e679",
      "name": "Simple Memory"
    },
    {
      "parameters": {
        "jsCode": "// 1. YETKİLİ LİSTESİ\nconst authorizedIds = [\n  YOUR_TELEGRAM_USER_ID_1, // Senin ana ID'n\n  YOUR_TELEGRAM_USER_ID_2  // Diğer hesabın/Ekip arkadaşın\n  // 987654321, // Zülfikar\n  // 456789123, // Nisa\n  // 321654987  // Berna\n];\n\n// 2. TEMEL VERİLERİ ÇEK\nconst rawData = $input.item.json;\nconst messageObj = rawData.message || rawData.callback_query?.message;\n\n// Eğer mesaj objesi yoksa hata vermemesi için koruma\nif (!messageObj) return { json: { isAuthorized: false, error: \"Mesaj bulunamadı.\" } };\n\nconst text = messageObj.text || messageObj.caption || '';\nconst chatId = messageObj.chat.id;\nconst userId = messageObj.from.id;\nconst userName = messageObj.from.first_name;\n\n// 3. YETKİ KONTROLÜ\nconst isAuthorized = authorizedIds.includes(userId);\n\n// 4. MESAJI PARÇALA (Komut & Parametreler)\nlet command = 'general';\nlet parameters = '';\n\nif (text.startsWith('/')) {\n  const parts = text.split(' ');\n  command = parts[0].toLowerCase().replace('/', '');\n  parameters = parts.slice(1).join(' ');\n}\n\n// 5. ÇIKTIYI HAZIRLA (Dosya bilgilerini dışa çıkarıyoruz)\nreturn {\n  json: {\n    isAuthorized,\n    chatId,\n    userId,\n    userName,\n    command,\n    parameters,\n    fullMessage: text,\n    messageId: messageObj.message_id,\n    // Dosya varsa ID'sini buraya alıyoruz, yoksa null döner\n    fileId: messageObj.document ? messageObj.document.file_id : (messageObj.photo ? messageObj.photo[messageObj.photo.length - 1].file_id : null),\n    fileName: messageObj.document ? messageObj.document.file_name : \"image.jpg\",\n    rawData: rawData // Tüm orijinal paketi de her ihtimale karşı taşıyoruz\n  }\n};"
      },
